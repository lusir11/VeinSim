FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      T;
}

dimensions      [0 0 0 1 0 0 0];

internalField   uniform 300;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 293.15;  // 20°C coolant inlet
    }
    outlet
    {
        type            zeroGradient;
    }
    topWall
    {
        type            fixedValue;
        value           uniform 353.15;  // 80°C heat source on top wall
    }
    bottomWall
    {
        type            zeroGradient;    // adiabatic bottom
    }
    frontAndBack
    {
        type            empty;
    }
}
