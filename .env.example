# ==========================================
# ToffeeX Imitation — Environment Variables
# ==========================================
# Copy this file to .env and fill in values
#   cp .env.example .env

# ── Database (PostgreSQL) ──────────────────
POSTGRES_USER=tofeex
POSTGRES_PASSWORD=tofeex_dev_2026
POSTGRES_DB=tofeex_db
DATABASE_URL=postgresql+asyncpg://tofeex:tofeex_dev_2026@db:5432/tofeex_db

# ── Redis ──────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── MinIO Object Storage ───────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_secret
MINIO_BUCKET=tofeex-models

# ── Auth / JWT ─────────────────────────────
SECRET_KEY=change-me-to-random-secret-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── OpenFOAM Solver ───────────────────────
OPENFOAM_CASES_DIR=/opt/openfoam/cases
SOLVER_TIMEOUT_SECONDS=7200
SOLVER_MAX_PARALLEL=4

# ── Frontend ───────────────────────────────
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_WS_BASE_URL=ws://localhost:8000/api/v1/ws
